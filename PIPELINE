         reldir/confirmations/*.json
   - output
        	reldir/predicted/predicted.csv


Step-14: Correcting for species mismatch
========================================
   - script
         correct-predictions.py
   - input
         reldir/predicted/predicted.csv
         reldir/llm_entities/*/*.json
   - output
         reldir/predicted/predicted_corrected.csv


Step-15: Copy to GlyGen downloads folder
========================================
	$ mkdir /data/shared/glygen/downloads/lit_min/YYYY_MM_DD
	$ cp reldir/predicted/predicted_corrected.csv /data/shared/glygen/downloads/lit_min/YYYY_MM_DD/glycosylation_sites_GlycoSiteMiner_$REL.csv
	$ cd /data/shared/glygen/downloads/lit_min/
	$ chmod -R 775 YYYY_MM_DD
	$ rm current
	$ ln -s YYYY_MM_DD current


